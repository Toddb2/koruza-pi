#!/bin/bash -e

if [ ${EUID} -ne 0 ]; then
  echo "ERROR: This installation script must be run as root."
  exit 1
fi

UPGRADE_PACKAGE="$1"
UPGRADE_DIR=/tmp/upgrade-koruza-repo
if [ -z "${UPGRADE_PACKAGE}" ]; then
  # WARNING: The default clone URL below points to the upstream IRNAS repository.
  # Running this without a package argument will OVERWRITE all local modifications
  # (gpio_stepper.py, koruza-sensors ping-based measurements, alignment fixes, etc.)
  # with the unmodified original KORUZA code.
  # Pass a local package path as $1, or update the URL to your own fork first:
  #   sudo /koruza/upgrade /path/to/koruza-package.tar.bz2
  echo "ERROR: No upgrade package specified."
  echo "Pass the path to a locally-built package: sudo /koruza/upgrade /path/to/koruza-package.tar.bz2"
  echo "To build a package from this repo: ./make-package.sh"
  exit 1
fi

# Do not shutdown the vpn service as otherwise we may lose connectivity.
UPGRADE_SERVICES="koruza-nodewatcher koruza-gpio koruza-webui koruza-sensors koruza-spiral-scan koruza-alignment koruza-webcam"

update-rc.d watchdog remove
/etc/init.d/watchdog stop
sv -w 30 stop ${UPGRADE_SERVICES}

cp /koruza/config/koruza.conf /tmp/koruza.conf

tar -xf ${UPGRADE_PACKAGE} -C /

mv /tmp/koruza.conf /koruza/config/koruza.conf

/koruza/install-packages
/koruza/install-config

sv -w 30 start ${UPGRADE_SERVICES}

rm -rf "${UPGRADE_DIR}"
